{
  "version": "1.0",
  "collections": {
    "research_notebooks": {
      "description": "Store individual independent artistic research notebooks/workspaces",
      "fields": {
        "id": "string",
        "userId": "string",
        "title": "string",
        "subtitle": "string (optional)",
        "description": "string (optional)",
        "coverImage": "string (optional)",
        "status": "string ('active' | 'archived')",
        "createdAt": "timestamp (ISO)",
        "updatedAt": "timestamp (ISO)",
        "language": "string ('en' | 'pt')",
        "tags": "array of strings (optional)",
        "favorite": "boolean (optional)"
      }
    },
    "users": {
      "description": "Store registered user profiles synced from Google Auth",
      "fields": {
        "uid": "string",
        "email": "string",
        "displayName": "string",
        "photoURL": "string",
        "createdAt": "timestamp (ISO)",
        "lastLoginAt": "timestamp (ISO)",
        "name": "string (optional)",
        "bio": "string (optional)",
        "artisticArea": "string (optional)",
        "website": "string (optional)",
        "instagram": "string (optional)",
        "preferredLanguage": "string ('en' | 'pt', optional)",
        "privacyConsentAccepted": "boolean",
        "analyticsConsentAccepted": "boolean",
        "consentAcceptedAt": "timestamp (ISO)",
        "consentHistory": "array of objects"
      }
    },
    "journal": {
      "description": "Store personal research diary entries of artists",
      "fields": {
        "userId": "string",
        "title": "string",
        "content": "string",
        "tags": "array of strings",
        "associatedConcepts": "array of strings",
        "createdAt": "timestamp (ISO)"
      }
    },
    "concepts": {
      "description": "Store concepts seeded or generated by artists",
      "fields": {
        "userId": "string",
        "name": "string",
        "description": "string",
        "status": "string ('seed' | 'growing' | 'mature')",
        "associations": "array of strings",
        "questions": "array of strings",
        "references": "array of references",
        "connections": "array of concept connections",
        "createdAt": "timestamp (ISO)"
      }
    },
    "insights": {
      "description": "Store synthetic insight reports generated by Gemini model",
      "fields": {
        "userId": "string",
        "patterns": "array of patterns",
        "associations": "array of strings",
        "questions": "array of strings",
        "suggestedReferences": "array of references",
        "createdAt": "timestamp (ISO)"
      }
    },
    "analytics_events": {
      "description": "Store analytical milestones to measure user retention loops",
      "fields": {
        "userId": "string",
        "userEmail": "string",
        "eventType": "string",
        "createdAt": "timestamp (ISO)",
        "metadata": "map"
      }
    },
    "admin_users": {
      "description": "Store defined role-based administrators of ATLAS platform",
      "fields": {
        "email": "string (lowercase, document ID)",
        "role": "string ('super_admin' | 'admin')",
        "createdAt": "timestamp (ISO)"
      }
    },
    "exports": {
      "description": "Store exported documents generated by the artist or AI",
      "fields": {
        "userId": "string",
        "type": "string ('pdf' | 'memorial' | 'report' | 'summary')",
        "language": "string ('en' | 'pt')",
        "createdAt": "timestamp (ISO)",
        "status": "string ('pending' | 'success' | 'failed')",
        "content": "string (optional)",
        "title": "string (optional)",
        "version": "number",
        "metadata": "map (optional)"
      }
    },
    "portfolios": {
      "description": "Store custom curated portfolios of artworks, process logs, and concept seeds",
      "fields": {
        "id": "string",
        "userId": "string",
        "researchNotebookId": "string",
        "title": "string",
        "subtitle": "string (optional)",
        "artistStatement": "string",
        "template": "string ('minimal' | 'grid' | 'editorial')",
        "selectedEntries": "array of strings",
        "selectedConcepts": "array of strings",
        "createdAt": "timestamp (ISO)",
        "updatedAt": "timestamp (ISO)",
        "isPublic": "boolean (optional)"
      }
    },
    "feedback": {
      "description": "Store user-submitted beta feedback, ideas, suggestions and bugs",
      "fields": {
        "id": "string",
        "userId": "string",
        "userEmail": "string",
        "category": "string ('bug' | 'suggestion' | 'question' | 'idea' | 'other')",
        "title": "string",
        "description": "string",
        "attachment": "string (optional, screenshot Base64/URL)",
        "emailReplyConsent": "boolean",
        "browser": "string",
        "os": "string",
        "language": "string ('en' | 'pt')",
        "appVersion": "string",
        "notebookId": "string (optional)",
        "module": "string (optional)",
        "status": "string ('new' | 'review' | 'resolved' | 'archived')",
        "adminNotes": "string (optional)",
        "createdAt": "timestamp (ISO)",
        "updatedAt": "timestamp (ISO)"
      }
    }
  }
}
